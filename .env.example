# OKX API 配置 (必填)
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 运行模式
OKX_DEMO_MODE=True
CONFIRM_REAL_MONEY=False
OKX_MARGIN_MODE=cross
OKX_POSITION_MODE=net

# 告警配置 (可选但强烈建议)
# 支持: dingtalk, lark, feishu, custom
ALERT_PROVIDER=dingtalk
ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token_here

# 交易参数
TRADE_SYMBOL=ETH/USDT
MAX_POSITION_PCT=0.95
