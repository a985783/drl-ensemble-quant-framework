# OKX API config.
# Leave blank for research/data-only workflows. Required for authenticated
# exchange calls and live/demo account operations.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# 运行模式
OKX_DEMO_MODE=True
CONFIRM_REAL_MONEY=False
OKX_MARGIN_MODE=cross
OKX_POSITION_MODE=net

# 告警配置 (可选但强烈建议)
# 支持: dingtalk, lark, feishu, custom
ALERT_PROVIDER=dingtalk
ALERT_WEBHOOK_URL=

# 交易参数
TRADE_SYMBOL=ETH/USDT
MAX_POSITION_PCT=0.95
